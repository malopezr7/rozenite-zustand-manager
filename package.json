{
  "name": "rozenite-zustand-manager-monorepo",
  "private": true,
  "type": "module",
  "description": "Workspace root for the rozenite-zustand-manager Rozenite plugin.",
  "license": "MIT",
  "author": "Manuel Lopez <malopezr7@gmail.com>",
  "homepage": "https://github.com/malopezr7/rozenite-zustand-manager#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/malopezr7/rozenite-zustand-manager.git"
  },
  "bugs": {
    "url": "https://github.com/malopezr7/rozenite-zustand-manager/issues"
  },
  "scripts": {
    "build": "pnpm --filter rozenite-zustand-manager build",
    "build:plugin": "pnpm --filter rozenite-zustand-manager build:plugin",
    "build:web": "pnpm --filter rozenite-zustand-manager build:web",
    "dev": "pnpm --filter rozenite-zustand-manager dev",
    "dev:web": "pnpm --filter rozenite-zustand-manager dev:web",
    "example:start": "pnpm --dir example start",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "husky",
    "preview": "pnpm --filter rozenite-zustand-manager preview",
    "test": "pnpm --filter rozenite-zustand-manager test",
    "typecheck": "pnpm --filter rozenite-zustand-manager typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
